#pragma once

// ---- WiFi (優先順位順: 1 → 2 → 3 にフォールバック) ----
const char* ssid1 = "";
const char* pass1 = "";
const char* ssid2 = "";
const char* pass2 = "";
const char* ssid3 = "";
const char* pass3 = "";

struct WiFiCred {
  const char* ssid;
  const char* password;
};

static const WiFiCred WIFI_LIST[] = {
  { ssid1, pass1 },
  { ssid2, pass2 },
  { ssid3, pass3 },
};

static const int WIFI_COUNT      = sizeof(WIFI_LIST) / sizeof(WIFI_LIST[0]);
static const int WIFI_TIMEOUT_MS = 10000;
